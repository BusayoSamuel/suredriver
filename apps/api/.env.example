# ── Local development (SQLite) ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-jwt-secret-change-in-production"
PORT=3000
NOMBA_MOCK="true"

# ── Nomba (leave empty for mock mode) ───────────────────────────────────────
# Sandbox: https://developer.nomba.com
NOMBA_BASE_URL="https://sandbox.nomba.com"
NOMBA_CLIENT_ID=""
NOMBA_CLIENT_SECRET=""
NOMBA_ACCOUNT_ID=""
NOMBA_WEBHOOK_SECRET=""

# Production Nomba:
# NOMBA_MOCK="false"
# NOMBA_BASE_URL="https://api.nomba.com"

# ── Production (Supabase Postgres) ──────────────────────────────────────────
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
# Use Transaction pooler (port 6543) on Render with ?pgbouncer=true

PLATFORM_FEE_PERCENT="0.15"
