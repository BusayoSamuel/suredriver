# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Session pooler (port 5432) — use for migrations and local dev:
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
# Transaction pooler (port 6543) — use on Render production:
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
JWT_SECRET="dev-jwt-secret-change-in-production"
PORT=3000

# ── Nomba payments (Hackathon 2026) ───────────────────────────────────────
# Sandbox: NOMBA_BASE_URL=https://sandbox.nomba.com + TEST client credentials
# Live:    NOMBA_BASE_URL=https://api.nomba.com + LIVE client credentials
#
# Golden rule (fixes most 403s):
#   accountId HEADER = parent account on EVERY request (auth + API calls)
#   sub-account id   = URL path or body field only (never the header)
#
# Hackathon shared parent: f666ef9b-888e-4799-85ce-acb505b28023
# Your team sub-account id comes from the Nomba hackathon email → NOMBA_SUB_ACCOUNT_ID
NOMBA_MOCK="true"
NOMBA_BASE_URL="https://sandbox.nomba.com"
NOMBA_CLIENT_ID=""
NOMBA_CLIENT_SECRET=""
NOMBA_PARENT_ACCOUNT_ID="f666ef9b-888e-4799-85ce-acb505b28023"
NOMBA_SUB_ACCOUNT_ID=""
# Legacy alias for parent account (optional if NOMBA_PARENT_ACCOUNT_ID is set)
NOMBA_ACCOUNT_ID=""
NOMBA_WEBHOOK_SECRET=""
# Signing key from Nomba (dashboard webhook settings or hackathon email).
# Used to verify the nomba-signature header — see:
# https://developer.nomba.com/docs/api-basics/webhook
PUBLIC_API_URL="https://suredriver-api.onrender.com"

# ── Production (Supabase Postgres) ──────────────────────────────────────────
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

PLATFORM_FEE_PERCENT="0.15"
