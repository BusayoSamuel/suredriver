{
  "expo": {
    "name": "SureDriver",
    "slug": "suredriver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "suredriver",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.suredriver.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ng.suredriver.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1df36ace-f676-4eac-9ebb-99b931257260"
      }
    },
    "owner": "busayosamuel"
  }
}
