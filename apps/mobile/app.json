{
  "expo": {
    "name": "SureDriver",
    "slug": "suredriver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "suredriver",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.suredriver.app"
    },
    "android": {
      "package": "ng.suredriver.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
